{
  "name": "@kriya/core",
  "version": "0.0.1",
  "description": "Action registry + agent loop protocol for kriya desktop apps. Agents see your app's typed actions, not pixels.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "kriya": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "agent",
    "ai-agent",
    "kriya",
    "tauri",
    "mcp",
    "desktop",
    "llm",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandeepshekhar26/kriya.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/sandeepshekhar26/kriya#readme",
  "bugs": "https://github.com/sandeepshekhar26/kriya/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8"
  }
}
