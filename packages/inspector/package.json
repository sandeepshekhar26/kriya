{
  "name": "@kriya/inspector",
  "version": "0.3.0",
  "description": "Drop-in React inspector for kriya desktop apps — step log, filters, JSONL export, past-runs replay, approval modal, step-mode gate.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "agent",
    "kriya",
    "react",
    "inspector",
    "dev-tools",
    "tauri"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandeepshekhar26/kriya.git",
    "directory": "packages/inspector"
  },
  "homepage": "https://github.com/sandeepshekhar26/kriya#readme",
  "bugs": "https://github.com/sandeepshekhar26/kriya/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "peerDependencies": {
    "@kriya/core": "^0.0.1",
    "@tauri-apps/api": "^2",
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@kriya/core": "*",
    "@tauri-apps/api": "^2.1.1",
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "typescript": "^5.6.0"
  }
}
