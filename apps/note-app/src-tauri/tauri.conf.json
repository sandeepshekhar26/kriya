{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "note-app",
  "version": "0.0.1",
  "identifier": "dev.agentnative.noteapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "agent-native · notes",
        "width": 1140,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
